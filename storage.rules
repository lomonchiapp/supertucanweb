rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Lectura pública: cualquier persona puede ver imágenes de motos,
    // repuestos y noticias.
    match /bikes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /parts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Cualquier otra ruta requiere autenticación.
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
