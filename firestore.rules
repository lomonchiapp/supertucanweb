rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Catálogo público: lectura abierta para todo el mundo
    match /models/{modelId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Subcolección de colores por modelo
      match /colors/{colorId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /parts/{partId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /partsCategories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Noticias: solo las publicadas son legibles públicamente
    match /news/{newsId} {
      allow read: if resource.data.published == true || request.auth != null;
      allow write: if request.auth != null;
    }

    // Por defecto, cualquier otra colección requiere autenticación
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
